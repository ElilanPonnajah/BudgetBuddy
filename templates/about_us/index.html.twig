{% extends 'base.html.twig' %}

{% block title %}Over ons{% endblock %}

{% block body %}
<section class="py-5 bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <h1 class="fw-bold text-primary">Samen bouwen aan financieel vertrouwen</h1>
                <p class="mt-3 text-secondary">
                    Budget Buddy helpt gezinnen en studenten om grip te krijgen op hun geldzaken.
                    Met onze digitale tools, persoonlijke begeleiding en transparante inzichten geven we
                    iedereen de mogelijkheid om verantwoord te groeien.
                </p>
                <p class="text-secondary">
                    We geloven dat slimme keuzes beginnen met heldere informatie. Daarom combineren we
                    data, deskundigheid en een mensgerichte aanpak om jouw financiële toekomst
                    sterker te maken.
                </p>
            </div>
            <div class="col-lg-7">
                <img src="{{ asset('images/over-ons.png') }}" alt="Budget Buddy team in overleg" class="img-fluid rounded-4 shadow-sm">
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background-color: #f4f6fb;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-10">
                <h2 class="fw-semibold text-primary">Waarde voor gebruikers, partners en coaches</h2>
                <p class="mt-3 text-secondary">
                    Door samen te werken met onderwijsinstellingen, lokale gemeenten en financiële
                    experts bieden we een platform dat zowel betrouwbaar als vernieuwend is. We delen
                    kennis, ontwikkelen praktische trainingsmodules en zorgen dat iedere gebruiker direct
                    kan profiteren van bruikbare inzichten.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-6">
                <div class="p-4 h-100 rounded-4 shadow-sm" style="background-color: #512da8;">
                    <h3 class="text-white mb-3">Onze belofte</h3>
                    <p class="text-white-50 mb-4">
                        We blijven investeren in nieuwe functionaliteiten, menselijke ondersteuning en
                        duidelijke communicatie zodat iedereen met vertrouwen kan sparen, plannen en
                        dromen. Budget Buddy groeit met jouw doelen mee.
                    </p>
                    <a href="{{ path('app_contacts') }}" class="btn btn-light text-primary fw-semibold">Plan een kennismaking</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="p-4 h-100 rounded-4 border border-light-subtle">
                    <h3 class="fw-semibold text-primary mb-3">Voordelen voor jouw organisatie</h3>
                    <ul class="list-unstyled text-secondary mb-0">
                        <li class="d-flex mb-3">
                            <span class="badge rounded-pill bg-primary me-3">1</span>
                            <span>Toegang tot workshops en materialen voor financiële educatie.</span>
                        </li>
                        <li class="d-flex mb-3">
                            <span class="badge rounded-pill bg-primary me-3">2</span>
                            <span>Realtime dashboards die inzicht geven in spaar- en bestedingspatronen.</span>
                        </li>
                        <li class="d-flex mb-3">
                            <span class="badge rounded-pill bg-primary me-3">3</span>
                            <span>Bewezen methodiek met persoonlijke coaching door ervaren adviseurs.</span>
                        </li>
                        <li class="d-flex">
                            <span class="badge rounded-pill bg-primary me-3">4</span>
                            <span>Lokale impact door partnerschappen met scholen en maatschappelijke organisaties.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

