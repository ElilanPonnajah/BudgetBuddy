{% extends 'base.html.twig' %}

{% block title %}Over ons{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('contact-form');
            if (!form) {
                return;
            }const fields = form.querySelectorAll('input, textarea');
            const resetValidationState = () => {
                form.classList.remove('was-validated');
                fields.forEach((field) => {
                    field.classList.remove('is-invalid', 'is-valid');
                });
            };

            form.addEventListener('submit', (event) => {
                event.preventDefault();

                form.classList.add('was-validated');

                if (!form.checkValidity()) {
                    event.stopPropagation();
                    return;
                }

                form.reset();
                resetValidationState();
            });

            fields.forEach((field) => {
                field.addEventListener('input', () => {
                    if (!form.classList.contains('was-validated')) {
                        return;
                    }

                    if (field.checkValidity()) {
                        field.classList.remove('is-invalid');
                    }
                });
            });
        });
    </script>
{% endblock %}

{% block body %}
    <section class="py-5 bg-white">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-5">
                    <h1 class="fw-bold text-primary">Problemen of vragen?</h1>
                    <h3 class="fw-bold text-primary">Neem contact op met onze klantenservice.</h3>
                    <p class="mt-3 text-secondary">
                        Budget Buddy helpt gezinnen en studenten om grip te krijgen op hun geldzaken.
                        Met onze digitale tools, persoonlijke begeleiding en transparante inzichten geven we
                        iedereen de mogelijkheid om verantwoord te groeien.
                    </p>
                    <p class="text-secondary">
                        We geloven dat slimme keuzes beginnen met heldere informatie. Daarom combineren we
                        data, deskundigheid en een mensgerichte aanpak om jouw financiële toekomst
                        sterker te maken.
                    </p>
                </div>
                <div class="col-lg-7">
                    <img src="{{ asset('images/customer-service.png') }}" alt="Budget Buddy team in overleg" class="img-fluid rounded-4 shadow-sm">
                </div>
            </div>

        </div>
    </section>

    <section class="py-5 glass-section">
        <div class="container text-light">
            <div class="row">

                <div class="col-lg-8">
                    <div class="glass-panel glass-panel--light p-4 p-lg-5 h-100">
                        <h3 class="fw-semibold text-primary mb-4">Stuur ons een bericht</h3>
                        <form id="contact-form" action="" class="row needs-validation" novalidate>

                            <div class="mb-3 col-md-6">
                                <label for="firstname" class="form-label">Voornaam</label>
                                <input type="text" class="form-control" id="firstname" placeholder="Voornaam" required></input>
                                <div class="invalid-feedback">
                                    Voer je voornaam in.
                                </div>
                            </div>
                            <div class="mb-3 col-md-6">
                                <label for="lastname" class="form-label">Achternaam</label>
                                <input type="text" class="form-control" id="lastname" placeholder="Voornaam" required></input>
                                <div class="invalid-feedback">
                                    Voer je achternaam in.
                                </div>
                            </div>
                            <div class="mb-3 col-md-12">
                                <label for="email" class="form-label">E-mail</label>
                                <input type="email" class="form-control" id="email" placeholder="johannes@example.com" required>
                                <div class="invalid-feedback">
                                    Voer een geldig e-mailadres in.
                                </div>
                            </div>
                            <div class="mb-3 col-md-12">
                                <label for="message" class="form-label">Bericht</label>
                                <textarea class="form-control" id="message" rows="6" required></textarea>
                                <div class="invalid-feedback">
                                    Voer een bericht in.
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100">Verstuur</button>
                            </div>
                        </form>
                    </div>

                </div>
                <div class="col-lg-4">
                    <div class="glass-panel glass-panel--dark p-4 p-lg-5 h-100">
                        <h3 class="text-white mb-4">Informatie</h3>
                        <div class="list-group list-group-flush">
                            <div class="list-group-item bg-transparent border-0 px-0 text-white">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <h5 class="mb-2">Telefoonnummer</h5>
                                </div>
                                <p class="mb-2 fs-5 fw-semibold">(+31) 070 123 45 67</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <button class="btn btn-light text-primary" onclick="window.location.href='tel:+310701234567'">Bel direct</button>
                                </div>
