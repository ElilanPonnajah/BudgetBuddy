                                    <h5 class="mb-2">Hoofdkantoor</h5>
                                </div>
                                <p class="mb-2">Schedeldoekshaven 506<br>2511 EP Den Haag</p>
                                <a href="https://www.google.com/maps/place/Schedeldoekshaven+506,+2511+EP+Den+Haag" class="btn btn-light text-primary">Bekijk route</a>
                                <small class="d-block mt-2 text-white-50">Open van maandag t/m donderdag van 9:00 tot 17:00.</small>
                            </div>
                            <div class="list-group-item bg-transparent border-0 px-0 text-white">
