{% extends 'base.html.twig' %}

{% block title %}Hello OverviewController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }

    .user-header {
        background-color: #f8f9fa;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: {% if users %}
                            flex-start;
                            {% else %}
                            center;
                            {% endif %};
        gap: 1rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        scroll-behavior: smooth;
        overflow-x: auto;

    %}
    .user-pic {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    .user-pic:hover {
        border-color: #0d6efd;
        transform: scale(1.05);
    }
</style>

<div class="container">
    <div class="row justify-content-center pt-3">
        <div class="col-md">
            <h1 class="text-center">Overzicht</h1>
        </div>

    </div>

    <header class="pt-3 row">
        <h2>Gebruikers</h2>
        <div class="user-header">
            {% if users %}

            {% for user in users %}
                <div class=" d-flex flex-column align-items-center">
                    <a href="{{ path('user_detail', {'id': user.id}) }}">
                        <img src="{{ user.imgUrl }}" alt="{{ user.firstName }}" class="user-pic" data-bs-toggle="modal" data-bs-target="#user{{ user.id }}Modal">
                    </a>
                    <h5>{{ user.firstName }} {{ user.lastName }}</h5>
                </div>
            {% endfor %}
                <div class="d-flex flex-column align-items-center" style="min-width: 100px;">
                    <a href="{{ path('app_overview_add') }}">
                        <div class="user-pic d-flex align-items-center justify-content-center bg-primary bg-opacity-10" style="border: 2px dashed #0d6efd; width: 100px; height: 100px;">
                            <i class="bi bi-plus-circle text-primary" style="font-size: 2.8rem;"></i>
                        </div>
                    </a>

                    <h5 class="mt-2" style="font-size: 1.1rem;">Toevoegen</h5>
                </div>

            {% else %}
                <div class="d-flex flex-column align-items-center">
                    <p>No users found.</p>
                    <a href="{{ path('app_overview_add') }}" class="btn btn-primary">Add user</a>
                </div>

            {% endif %}
        </div>

    </header>







</div>
{% endblock %}
