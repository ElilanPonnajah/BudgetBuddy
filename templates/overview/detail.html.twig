{% extends 'base.html.twig' %}

{% block title %}Hello OverviewController!{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<style>
    .example-wrapper {
        margin: 1em auto;
        max-width: 800px;
        width: 95%;
        font: 18px/1.5 sans-serif;
    }

    .example-wrapper code {
        background: #F5F5F5;
        padding: 2px 6px;
    }

    .user-header {
        background-color: #f8f9fa;
        padding: 1rem;
        display: flex;
        align-items: center;
        /* Let Bootstrap utilities control justification */
        gap: 1rem;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
        scroll-behavior: smooth;
        overflow-x: auto;
    }

    .user-pic {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .user-pic:hover {
        border-color: #0d6efd;
        transform: scale(1.05);
    }
    .cat-item {
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .cat-item:hover {
        transform: scale(1.05);
    }
</style>

<div class="container">
    <div class="row justify-content-center pt-3">
        <div class="col-md">
            <h1 class="text-center">Overzicht</h1>
        </div>

    </div>

    <header class="pt-3">
        <div class="d-flex justify-content-between">
            <h2>Gebruikers</h2>
            <a class="btn btn-danger" href="{{ path('app_overview_delete', {'id': user.id}) }}" style="height: fit-content">Verwijder {{ user.firstName }} {{ user.lastName }}</a>
        </div>

        <div class="user-header {% if users is empty %}justify-content-center{% endif %}">
            {% if users %}

                {% for user in users %}
                    <div class="d-flex flex-column align-items-center">
                        <a href="{{ path('user_detail', {'id': user.id}) }}">
                            <img src="{{ user.imgUrl }}" alt="{{ user.firstName }}" class="user-pic"
                                 data-bs-toggle="modal" data-bs-target="#user{{ user.id }}Modal">
                        </a>
                        <h5>{{ user.firstName }} {{ user.lastName }}</h5>
                    </div>
                {% endfor %}
                <div class="d-flex flex-column align-items-center">
                    <a href="{{ path('app_overview_add') }}" class="text-decoration-none">
                        <div class="user-pic d-flex align-items-center justify-content-center bg-primary bg-opacity-10" style="border: 2px dashed #0d6efd;">
                            <i class="bi bi-plus-circle text-primary" style="font-size: 3rem;"></i>
                        </div>
                    </a>
                    <h5 class="text-center">Toevoegen</h5>
                </div>

            {% else %}
                <div class="d-flex flex-column align-items-center">
                    <p>No users found.</p>
                    <a href="{{ path('app_overview_add') }}" class="btn btn-primary">Add user</a>
                </div>

            {% endif %}
        </div>

    </header>

    <div class="row justify-content-center pt-3">
        <div class="bg-light p-3">
            <div class="row gap-4 justify-content-center" style="">
                <div class="col-md-4  text-center mt-5 " style="background-color: #eaeaea">
                    <h3 class="text-success-emphasis">Meest recente inkomen</h3>
                    <div>
                        <h4>
                            {# Find most recent income (amount > 0) #}
                            {% set recent_income = null %}
                            {% set recent_income_ts = 0 %}
                            {% for t in transactions %}
                                {% if t.amount is not null and (t.amount + 0) > 0 %}
                                    {% set ts = t.transactionDate ? (t.transactionDate|date('U')) : 0 %}
                                    {% if ts > recent_income_ts %}
                                        {% set recent_income = t %}
                                        {% set recent_income_ts = ts %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}

                            {% if recent_income is null %}
                                Geen inkomsten.
                            {% else %}
                                <div class="d-flex flex-column align-items-center">
                                    <div class="fw-semibold">{{ recent_income.description }}</div>
                                    <div class="text-success">
                                        {{ recent_income.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                        <small class="text-muted">&middot; {{ recent_income.transactionDate|date('d-m-Y') }}</small>
                                    </div>
                                </div>
                            {% endif %}
                        </h4>
                    </div>
                </div>
                <div class="col-md-3 text-center" style="background-color: #eaeaea">
                    <h3>BUDGET</h3>
                    <div>
                        {% set budget = 0 %}
                        {% for transaction in transactions %}
                            {% set budget = budget + (transaction.amount + 0) %}
                        {% endfor %}
                        <h4 class="
                            {% if budget > 0 %}
                                text-success
                            {% elseif budget < 0 %}
                                text-danger
                            {% else %}
                                text-secondary
                            {% endif %}
                        "> {{ budget |format_currency('EUR', {rounding_mode: 'floor'}) }}</h4>
                    </div>
                    <div>
                        <h2 class="
                            {% if budget > 0 %}
                                text-success-emphasis">
                                Goed Bezig!
                            {% elseif budget < 0 %}
                                text-danger">
                                Let op!
                            {% else %}
                                text-secondary">
                                {% if transactions is empty %}
                                    Voeg een transactie toe om je budget te zien!

                                {% else %}
                                    Niet goed, Niet slecht!
                                {% endif %}

                            {% endif %}

                        </h2>
                    </div>
                </div>
                <div class="col-md-4 text-center mt-5" style="background-color: #eaeaea">
                    <h3 class="text-danger">Meest recente uitgaven</h3>
                    <div>
                        <h4>
                            {# Find most recent expense (amount < 0) #}
                            {% set recent_expense = null %}
                            {% set recent_expense_ts = 0 %}
                            {% for t in transactions %}
                                {% if t.amount is not null and (t.amount + 0) < 0 %}
                                    {% set ts = t.transactionDate ? (t.transactionDate|date('U')) : 0 %}
                                    {% if ts > recent_expense_ts %}
                                        {% set recent_expense = t %}
                                        {% set recent_expense_ts = ts %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}

                            {% if recent_expense is null %}
                                Geen transacties.
                            {% else %}
                                <div class="d-flex flex-column align-items-center">
                                    <div class="fw-semibold">{{ recent_expense.description }}</div>
                                    <div class="text-danger">
                                        {{ recent_expense.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                        <small class="text-muted">&middot; {{ recent_expense.transactionDate|date('d-m-Y') }}</small>
                                    </div>
                                </div>
                            {% endif %}
                        </h4>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <div class="row justify-content-center pt-5">
        <div class="col-md">
            <h3 class="">Budget balans per maand</h3>
        </div>
        <div class="row">
            <canvas id="myChart" style="width: 100%; height: 400px;"></canvas>
        </div>
    </div>

    <div class="row justify-content-center pt-5">
        <div class="col-md d-flex justify-content-between mb-2">
            <h3 class="">Uitgaven per categorie</h3>
            <div class="">
                <a href="{{ path("app_choose_category_edit", {'id': user.id}) }}" class="btn btn-warning" >bewerk categorie
                    toe</a>
                <a class="btn btn-primary" href="{{ path("app_overview_category_add", {'id': user.id}) }}">Voeg categorie
                    toe</a>
            </div>

        </div>
        <div class="row user-header">
            {% for category in default_categories %}
                <a class="cat-item col-md d-flex justify-content-center flex-column align-items-center" href="{{ path("app_overview_category_show", {'id': category.id, 'userId': user.id}) }}" style="text-decoration: none; color: inherit">
                    <div class="d-flex justify-content-center flex-column align-items-center">
                        <div class="">
                            <i class="{{ category.icon }}" style="font-size: 5rem"></i>
                        </div>
                        <h4>{{ category.name }}</h4>
                    </div>
                </a>

            {% endfor %}
            {% for category in custom_categories %}
                <a class="cat-item col-md d-flex justify-content-center flex-column align-items-center" href="{{ path("app_overview_category_show", {'id': category.id, 'userId': user.id}) }}" style="text-decoration: none; color: inherit">
                    <div class="d-flex justify-content-center flex-column align-items-center">
                        <div class="">
                            <i class="{{ category.icon }}" style="font-size: 5rem"></i>
                        </div>
                        <h4>{{ category.name }}</h4>
                    </div>
                </a>

            {% endfor %}


        </div>
    </div>
    <div class="row justify-content-center pt-5 gap-2">
        <div class="d-flex justify-content-between">
            <h3 class="">Uitgaven Historie</h3>
            <div class="">
                <a href="{{ path("app_choose_transaction_delete", {'id': user.id}) }}" class="btn btn-danger" >Verwijder Transactie</a>
                <a class="btn btn-primary" href="{{ path('app_overview_transaction_add' , {'id': user.id}) }}">Voeg Transactie toe</a>
            </div>
        </div>
        <div class="col-md d-flex justify-content-center flex-column gap-3 bg-secondary p-3 rounded-2">
            {% set transactionsLoop = 0 %}
            {% set maxTransactions = 3 %}

            {% for t in transactions %}
                {% if (t.amount + 0) < 0 %}
                    {% set transactionsLoop = transactionsLoop + 1 %}
                    {% if transactionsLoop <= maxTransactions %}
                    <a href="{{ path('app_show_transaction_details' , {'id': t.id}) }}" style="text-decoration: none; color: inherit">
                        <div class="row" >
                            <div class="col-md" >
                                <div class="card" >
                                    <div class="card-body d-flex justify-content-between">
                                        <div class="">
                                            <h5 class="card-title">{{ t.description }}</h5>
                                            <p class="card-text text-secondary">Categorie: {{ t.category.name }}</p>
                                            <small class="card-text text-secondary">{{ t.transactionDate|date('d-m-Y') }}</small>
                                            <!-- Toont de datum van de transactie in het formaat dag-maand-jaar -->

                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <h3 class="p-0 m-0 text-danger">
                                                {{ t.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                                <!-- rounding mode = hoe het wordt afgerond bijv: 10.99 word 10, -3.7 wordt -4-->
                                            </h3>
                                            <i class="bi bi-dash " style="font-size: 3rem"></i>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                    {% endif %}

                    <!-- dit laat alleen de uitgaven zien -->
                {% endif %}
            {% endfor %}
            <div class="row d-flex justify-content-center text-center align-items-center text-white">
                {% if transactions|length == 0 %}
                    <p>Geen transacties gevonden</p>
                {% else %}
                    {% if transactionsLoop > maxTransactions %}
                        <a class="btn btn-primary text-center" href="{{ path('app_show_transaction', {'id': user.id, 'type': 'uitgaven'}) }}" style="width: fit-content;">Bekijk Alle Inkomen</a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>

        <div class="row justify-content-center pt-5 gap-2">
            <div class="d-flex justify-content-between">
                <h3 class="">Inkomen Historie</h3>
                <div class="">
                    <a href="{{ path("app_choose_transaction_delete", {'id': user.id}) }}" class="btn btn-danger" >Verwijder Transactie</a>
                    <a class="btn btn-primary" href="{{ path('app_overview_transaction_add', {'id': user.id}) }}">Voeg Transactie toe</a>
                </div>
                <!-- zodra je dit klikt wordt je gestuurd naar de voeg transactie pagina toe -->
            </div>
            <div class="col-md d-flex justify-content-center flex-column gap-3 bg-secondary p-3 rounded-2">
                {% set transactionsLoop = 0 %}
                {% for t in transactions %}
                    {% if (t.amount + 0) > 0 %}
                        {% set transactionsLoop = transactionsLoop + 1 %}
                        {% if transactionsLoop <= maxTransactions %}
                        <!-- dit laat alleen de inkomsten zien -->
                        <a href="{{ path('app_show_transaction_details' , {'id': t.id}) }}" style="text-decoration: none; color: inherit">
                        <div class="row">
                            <div class="col-md">
                                <div class="card">
                                    <div class="card-body d-flex justify-content-between">
                                        <div class="">
                                            <h5 class="card-title">{{ t.description }}</h5>
                                            <p class="card-text text-secondary">Categorie: {{ t.category.name }}</p>
                                            <small class="card-text text-secondary">{{ t.transactionDate|date('d-m-Y') }}</small>
                                            <!-- Toont de datum van de transactie in het formaat dag-maand-jaar -->

                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <h3 class="p-0 m-0 text-success">
                                                {{ t.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                                <!-- rounding mode = hoe het wordt afgerond bijv: 10.99 word 10, -3.7 wordt -4-->
                                            </h3>
                                            <i class="bi bi-plus-lg " style="font-size: 3rem"></i>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                        </a>
                        {% endif %}


                    {% endif %}
                {% endfor %}

                <div class="row d-flex justify-content-center text-center align-items-center text-white">
                    {% if transactions|length == 0 %}
                        <p>Geen transacties gevonden</p>
                    {% else %}

                    {% endif %}
                    {% if transactionsLoop > maxTransactions %}
                        <a class="btn btn-primary text-center" href="{{ path('app_show_transaction', {'id': user.id, 'type': 'inkomen'}) }}" style="width: fit-content;">Bekijk Alle Inkomen</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>

        
        document.addEventListener('turbo:load', function() {
            console.log('Chart.js version:', Chart.version);

            // Calculate monthly budgets from transactions
            // Check if transactionsJson exists, fallback to empty array
            const transactionsData = {{ transactionsJson|default([])|json_encode|raw }};
            console.log('Transactions raw:', transactionsData);

            // Convert to array if it's an object (Doctrine collection)
            const transactions = Array.isArray(transactionsData) ? transactionsData : Object.values(transactionsData);
            console.log('Transactions array:', transactions);

            // Show first transaction structure
            if (transactions.length > 0) {
                console.log('First transaction keys: ' + Object.keys(transactions[0]).join(', '));
                console.log('First transaction: ' + JSON.stringify(transactions[0]));
            }

            // Get current year
            const currentYear = new Date().getFullYear();
            console.log('Current year:', currentYear);

            // Initialize monthly data
            const monthlyData = {
                'Jan': 0, 'Feb': 0, 'Mar': 0, 'Apr': 0,
                'May': 0, 'Jun': 0, 'Jul': 0, 'Aug': 0,
                'Sep': 0, 'Oct': 0, 'Nov': 0, 'Dec': 0
            };

            const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

            // Process transactions and sum by month (current year only)
            let processedCount = 0;
            let skippedReasons = { noDate: 0, noAmount: 0, wrongYear: 0 };

            transactions.forEach(transaction => {
                console.log('Processing transaction:', transaction);

                // The date is now a simple string in format 'Y-m-d H:i:s'
                let dateString = transaction.transactionDate;

                console.log('Date string extracted:', dateString);

                if (!dateString) {
                    skippedReasons.noDate++;
                    console.log('Skipped - missing date');
                    return;
                }

                if (!transaction.amount) {
                    skippedReasons.noAmount++;
                    console.log('Skipped - missing amount');
                    return;
                }

                const date = new Date(dateString);
                const year = date.getFullYear();

                console.log('Transaction date:', dateString, 'Year:', year, 'Amount:', transaction.amount);

                // Only include transactions from current year
                if (year === currentYear) {
                    const monthIndex = date.getMonth();
                    const monthName = monthNames[monthIndex];
                    const amount = parseFloat(transaction.amount);
                    monthlyData[monthName] += amount;
                    processedCount++;
                    console.log('Added to month', monthName, ':', amount, 'Total now:', monthlyData[monthName]);
                } else {
                    skippedReasons.wrongYear++;
                    console.log('Skipped - not current year:', year);
                }
            });

            console.log('Processed', processedCount, 'transactions from', currentYear);
            console.log('Monthly data:', monthlyData);

            // Use monthly data directly (not cumulative)
            const budgetData = monthNames.map(month => monthlyData[month]);

            console.log('Budget data:', budgetData);

            // Calculate budget goal and target lines
            const maxBudget = Math.max(...budgetData);
            const minBudget = Math.min(...budgetData);
            const avgBudget = budgetData.reduce((a, b) => a + b, 0) / 12;

            console.log('Max:', maxBudget, 'Min:', minBudget, 'Avg:', avgBudget);

            // Create the chart
            const canvas = document.getElementById('myChart');
            if (!canvas) {
                console.error('Canvas element not found!');
                return;
            }

            const ctx = canvas.getContext('2d');
            const myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: monthNames,
                    datasets: [{
                        label: 'Monthly Budget Balance',
                        data: budgetData,
                        backgroundColor: '#c0c0c0',
                        borderColor: '#999',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '€' + value.toFixed(0);
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Budget: €' + context.parsed.y.toFixed(2);
                                }
                            }
                        }
                    }
                }
            });

            console.log('Chart created successfully:', myChart);
            myChart.update();
        });
    </script>
{% endblock %}
