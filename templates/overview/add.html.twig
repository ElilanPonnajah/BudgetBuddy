{% extends 'base.html.twig' %}

{% block title %}Hello OverviewController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="container">
        <h1 class="my-4">{{ formText }}</h1>

        {{ form(form) }}
        {% if user == null %}
            <a href="{{ path('app_overview') }}" type="submit" class="btn btn-secondary">Annuleren</a>
        {% else %}
            <a href="{{ path('user_detail', {'id': user.id}) }}" type="submit" class="btn btn-secondary">Annuleren</a>
        {% endif %}
        {% if type == 'edit' %}
            <a href="{{ path('category_delete', {'id': item.id, 'userId': user.id}) }}" type="submit" class="btn btn-danger">Verwijderen</a>
        {% endif %}

    </div>
{% endblock %}
