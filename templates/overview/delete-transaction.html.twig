{% extends 'base.html.twig' %}

{% block title %}Delete Category{% endblock %}

{% block body %}
<style>
    .category-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .category-item {
        text-decoration: none;

        color: #333;
        transition: 0.2s;
    }

    .category-item:hover {
        background-color: #ffecec;
        border-color: #ff7b7b;
        border-radius: 10px;
    }

    .category-icon {
        font-size: 2rem;
        margin-bottom: 5px;
    }
</style>

<div class="container">

    <h2>Uitgaven</h2>
    <div class="category-grid">
        <div class="col-md d-flex justify-content-center flex-column gap-3 bg-secondary p-3 rounded-2">
            {% for t in transactions %}
                {% if t.amount < 0 %}
                    <a class="category-item" href="{{ path('transaction_delete', {'id': t.id, 'userId': user.id}) }}">
                        <!-- dit laat alleen de uitgaven zien -->
                        <div class="row">
                            <div class="col-md">
                                <div class="card category-item">
                                    <div class="card-body d-flex justify-content-between">
                                        <div class="">
                                            <h5 class="card-title">{{ t.description }}</h5>
                                            <p class="card-text text-secondary">Categorie: {{ t.category.name }}</p>
                                            <small class="card-text text-secondary">{{ t.transactionDate|date('d-m-Y') }}</small>
                                            <!-- Toont de datum van de transactie in het formaat dag-maand-jaar -->

                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <h3 class="p-0 m-0 text-danger">
                                                {{ t.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                                <!-- rounding mode = hoe het wordt afgerond bijv: 10.99 word 10, -3.7 wordt -4-->
                                            </h3>
                                            <i class="bi bi-dash " style="font-size: 3rem"></i>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>

                {% endif %}
            {% endfor %}

            <div class="row d-flex justify-content-center text-center align-items-center text-white">
                {% if transactions.empty %}
                    <p>Geen transacties gevonden</p>
                {% endif %}
            </div>
        </div>
    </div>

    <h2>Inkomen</h2>
    <div class="category-grid">
        <div class="col-md d-flex justify-content-center flex-column gap-3 bg-secondary p-3 rounded-2">

            {% for t in transactions %}
                {% if t.amount > 0 %}
                    <!-- dit laat alleen de inkomsten zien -->
                <a class="category-item" href="{{ path('transaction_delete', {'id': t.id, 'userId': user.id}) }}">
                    <div class="row">
                        <div class="col-md">
                            <div class="card category-item">
                                <div class="card-body d-flex justify-content-between">
                                    <div class="">
                                        <h5 class="card-title">{{ t.description }}</h5>
                                        <p class="card-text text-secondary">Categorie: {{ t.category.name }}</p>
                                        <small class="card-text text-secondary">{{ t.transactionDate|date('d-m-Y') }}</small>
                                        <!-- Toont de datum van de transactie in het formaat dag-maand-jaar -->

                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <h3 class="p-0 m-0 text-success">
                                            {{ t.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                            <!-- rounding mode = hoe het wordt afgerond bijv: 10.99 word 10, -3.7 wordt -4-->
                                        </h3>
                                        <i class="bi bi-plus-lg " style="font-size: 3rem"></i>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </a>


                {% endif %}
            {% endfor %}

            <div class="row d-flex justify-content-center text-center align-items-center text-white">
                {% if transactions.empty %}
                    <p>Geen transacties gevonden</p>
                {% endif %}
            </div>
        </div>
    </div>


    <a href="{{ path('app_overview') }}" class="btn btn-primary">Back to Overview</a>
</div>


{% endblock %}

