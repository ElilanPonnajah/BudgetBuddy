{% extends 'base.html.twig' %}

{% block title %}Hello OverviewController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="container d-flex justify-content-center flex-column gap-3">
        <h1>{{ categoryText }}</h1>

        <div class="col-md d-flex justify-content-center flex-column gap-3 bg-secondary p-3 rounded-2">
            {% for t in transactions %}
            <a href="{{ path('app_show_transaction_details' , {'id': t.id}) }}" style="text-decoration: none; color: inherit">
                    <div class="row cat-item">
                        <div class="col-md">
                            <div class="card">
                                <div class="card-body d-flex justify-content-between">
                                    <div class="">
                                        <h5 class="card-title">{{ t.description }}</h5>
                                        <p class="card-text text-secondary">Categorie: {{ t.category.name }}</p>
                                        <small class="card-text text-secondary">{{ t.transactionDate|date('d-m-Y') }}</small>
                                        <!-- Toont de datum van de transactie in het formaat dag-maand-jaar -->

                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <h3 class="p-0 m-0 {% if t.amount < 0 %} text-danger {% else %} text-success {% endif %}">
                                            {{ t.amount | format_currency('EUR', {rounding_mode: 'floor'}) }}
                                            <!-- rounding mode = hoe het wordt afgerond bijv: 10.99 word 10, -3.7 wordt -4-->
                                        </h3>
                                        {% if t.amount < 0 %} <i class="bi bi-dash " style="font-size: 3rem"></i> {% else %} <i class="bi bi-plus-lg " style="font-size: 3rem"></i> {% endif %}
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
            </a>

                    <!-- dit laat alleen de uitgaven zien -->
            {% endfor %}
            {% if transactions is empty %}
                <h4 class="text-center text-white">Geen transacties gevonden</h4>
            {% endif %}
        </div>
        <div class="">
            <a class="btn btn-primary" href="{{ path('user_detail' , {'id': user.id}) }}">Terug naar overzicht</a>

        </div>
    </div>
{% endblock %}
